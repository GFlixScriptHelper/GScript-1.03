-- ============================================================
--  MAP WATCHER
-- ============================================================
local currentMap = nil

local function setupMapWatcher()
	local cr=workspace:FindFirstChild("CurrentRoom")
	if not cr then
		task.spawn(function()
			cr=workspace:WaitForChild("CurrentRoom",30)
			if not cr then return end
			setupMapWatcher()
		end)
		return
	end
	for _,child in ipairs(cr:GetChildren()) do
		if child:IsA("Model") then currentMap=child; break end
	end
	cr.ChildAdded:Connect(function(child)
		if child:IsA("Model") then task.wait(0.3); currentMap=child end
	end)
	cr.ChildRemoved:Connect(function() currentMap=nil end)
end

local function getMap()
	if currentMap and currentMap.Parent then return currentMap end
	if _G.ESP_currentMap then
		local m=_G.ESP_currentMap()
		if m then currentMap=m end
		return m
	end
	return nil
end

setupMapWatcher()

