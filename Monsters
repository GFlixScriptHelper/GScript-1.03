-- Watch for new monsters spawning in CurrentRoom
local notifiedMonsters = {}

local function watchForMonsters(map)
    if not map then return end
    local mf = map:FindFirstChild("Monsters")
    if not mf then return end

    -- Notify for already-present monsters on map load
    for _, obj in ipairs(mf:GetChildren()) do
        if not notifiedMonsters[obj] then
            notifiedMonsters[obj] = true
            task.spawn(function()
                task.wait(0.5)
                showNotification(obj.Name)
            end)
        end
    end

    -- Watch for new spawns
    mf.ChildAdded:Connect(function(child)
        if not notifyEnabled then return end
        if notifiedMonsters[child] then return end
        notifiedMonsters[child] = true
        task.wait(0.3)
        showNotification(child.Name)
    end)
end

-- Hook into the map watcher
local _origOnMapArrived = nil
local function startNotifyWatcher()
    local cr = workspace:FindFirstChild("CurrentRoom") or workspace:WaitForChild("CurrentRoom", 30)
    if not cr then return end
    cr.ChildAdded:Connect(function(child)
        if child:IsA("Model") then
            notifiedMonsters = {}
            task.wait(0.5)
            watchForMonsters(child)
        end
    end)
    cr.ChildRemoved:Connect(function()
        notifiedMonsters = {}
        -- Dismiss all popups
        for _, p in ipairs(activePopups) do
            pcall(function() p:Destroy() end)
        end
        activePopups = {}
    end)
    -- Current map
    for _, child in ipairs(cr:GetChildren()) do
        if child:IsA("Model") then
            watchForMonsters(child); break
        end
    end
end

