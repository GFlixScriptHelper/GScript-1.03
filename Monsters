local infoHud=nil; local infoHudVisible=false; local infoBody=nil

local function refreshInfoHud()
	if not infoBody then return end
	local map=getMap()
	local med=countItems("HealthKit"); local ban=countItems("Bandage")
	local entries={}
	if map then
		local mf=map:FindFirstChild("Monsters")
		if mf then for _,obj in ipairs(mf:GetChildren()) do
				local name=getDisplayName(obj.Name)
				local icon,col
				if isRainbow(obj.Name) then         icon="🌈"; col="#FF80FF"
				elseif isViolet(obj.Name) then      icon="💜"; col="#CC88FF"
				elseif isSquirm(obj.Name) then      icon="✨"; col="#FFE066"
				else                                icon="👾"; col="#FF5555" end
				table.insert(entries,'  <font color="'..col..'">'..icon..' '..name..'</font>')
			end end
	end
	local lines={
		'<font color="#64DC78">💊 Medkit: '..med..'</font>',
		'<font color="#00DCDC">🩹 Bandage: '..ban..'</font>',
		'<font color="#FF6464">👾 Twisteds:</font>',
	}
	if #entries==0 then table.insert(lines,'  <font color="#AAAAAA">None</font>')
	else for _,e in ipairs(entries) do table.insert(lines,e) end end
	infoBody.Text=table.concat(lines,"\n")
	infoHud.Size=UDim2.new(0,200,0,26+(#lines*18)+8)
end

