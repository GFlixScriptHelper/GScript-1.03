		else sendChat("Theres "..table.concat(names,", ").." In the Map!") end
	end)
	makeCBtn("✨ Squirm",Color3.fromRGB(120,90,15),3,function()
		local map=getMap(); local found=false
		if map then local mf=map:FindFirstChild("Monsters")
			if mf then for _,o in ipairs(mf:GetChildren()) do
					if isSquirm(o.Name) then found=true; break end
