		sendChat(found and "SQUIRM!!!" or "No Mains and No Squirm.")
	end)
	makeCBtn("💊 Medkit",Color3.fromRGB(25,85,35),4,function()
		local n=countItems("HealthKit")
		sendChat(n>0 and ("Theres "..n.." Medkit in the Map!") or "No Band and Medkit.")
	end)
	makeCBtn("🩹 Bandage",Color3.fromRGB(15,75,75),5,function()
		local n=countItems("Bandage")
		sendChat(n>0 and ("Theres "..n.." Bandage in the Map!") or "No Band and Medkit.")
	end)

	colBtn.MouseButton1Click:Connect(function()
		chatExpanded=not chatExpanded; cBody.Visible=chatExpanded
		colBtn.Text=chatExpanded and "▲" or "▼"
		chatPanel.Size=UDim2.new(0,200,0,chatExpanded and 168 or 24)
	end)

	RunService.Heartbeat:Connect(function()
		if not infoHud or not infoHud.Visible then chatPanel.Visible=false; return end
