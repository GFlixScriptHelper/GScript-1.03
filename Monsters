local RAINBOW_MONSTERS = {"Astro","Shelly","Vee","Dandy","Dyle","Sprout","Pebble"}
local VIOLET_MONSTERS  = {"Bassie","Flyte","Cocoa","Eggson"}
local SQUIRM_ONLY      = {"Squirm"}
local MONSTER_NAMES = {
	Astro="Twisted Astro",Shelly="Twisted Shelly",Vee="Twisted Vee",
	Dandy="Twisted Dandy",Dyle="Twisted Dyle",Sprout="Twisted Sprout",
	Pebble="Twisted Pebble",Squirm="Twisted Squirm",
	Bassie="Twisted Bassie",Flyte="Twisted Flyte",
	Cocoa="Twisted Cocoa",Eggson="Twisted Eggson",
}

local function isRainbow(name)
	local l=name:lower()
	for _,k in ipairs(RAINBOW_MONSTERS) do if l:find(k:lower()) then return true end end
	return false
end
local function isViolet(name)
	local l=name:lower()
	for _,k in ipairs(VIOLET_MONSTERS) do if l:find(k:lower()) then return true end end
	return false
end
local function isSquirm(name)
	local l=name:lower()
	for _,k in ipairs(SQUIRM_ONLY) do if l:find(k:lower()) then return true end end
	return false
end
local function getDisplayName(name)
	local l=name:lower()
	for k,d in pairs(MONSTER_NAMES) do if l:find(k:lower()) then return d end end
	return "Twisted "..name:gsub("[Mm]onster",""):gsub("^%s+",""):gsub("%s+$","")
end
local function countItems(match)
	local map=getMap(); if not map then return 0 end
	local f=map:FindFirstChild("Items"); if not f then return 0 end
	local c=0
	for _,o in ipairs(f:GetChildren()) do
		if o.Name:lower():find(match:lower()) then c=c+1 end
	end
	return c
end

-- ============================================================
--  SEND CHAT
-- ============================================================
local function sendChat(msg)
	local ok=pcall(function()
		local rs=game:GetService("ReplicatedStorage")
		local ce=rs:FindFirstChild("DefaultChatSystemChatEvents")
		if not ce then error("x") end
		local sm=ce:FindFirstChild("SayMessageRequest")
		if not sm then error("x") end
		sm:FireServer(msg,"All")
	end)
	if ok then return end
	pcall(function()
		local tcs=game:GetService("TextChatService")
		local ch=tcs.TextChannels:WaitForChild("RBXGeneral",1)
		if ch then ch:SendAsync(msg) end
	end)
end

