    monitorLabel.BackgroundTransparency=1; monitorLabel.Text="No map detected."
    monitorLabel.TextColor3=Color3.fromRGB(200,210,240)
    monitorLabel.Font=Enum.Font.FredokaOne; monitorLabel.TextSize=11
    monitorLabel.TextXAlignment=Enum.TextXAlignment.Left
    monitorLabel.TextYAlignment=Enum.TextYAlignment.Top
    monitorLabel.TextWrapped=true; monitorLabel.RichText=true
    monitorLabel.Parent=f
