local monitorLabel=nil

local function buildMonitorLabel()
	if monitorLabel then return end
	local f=Instance.new("Frame")
	f.Size=UDim2.new(1,-4,0,80); f.BackgroundColor3=Color3.fromRGB(14,14,22)
	f.BorderSizePixel=0; f.LayoutOrder=2; f.Parent=scrollFrame
	makeCorner(f,8); makeStroke(f,Color3.fromRGB(45,45,70),1,0)
	monitorLabel=Instance.new("TextLabel")
	monitorLabel.Size=UDim2.new(1,-10,1,0); monitorLabel.Position=UDim2.new(0,6,0,0)
	monitorLabel.BackgroundTransparency=1; monitorLabel.Text="No map detected."
	monitorLabel.TextColor3=Color3.fromRGB(200,210,240)
	monitorLabel.Font=Enum.Font.FredokaOne; monitorLabel.TextSize=11
	monitorLabel.TextXAlignment=Enum.TextXAlignment.Left
	monitorLabel.TextYAlignment=Enum.TextYAlignment.Top
	monitorLabel.TextWrapped=true; monitorLabel.RichText=true
	monitorLabel.Parent=f
end

local function refreshMonitor()
	if not monitorLabel then return end
	local map=getMap()
	if not map then monitorLabel.Text="No map detected."; return end
	local mf=map:FindFirstChild("Monsters")
	if not mf or #mf:GetChildren()==0 then
		monitorLabel.Text='<font color="#AAAAAA">No monsters in map.</font>'; return
	end
	local lines={}
	for _,obj in ipairs(mf:GetChildren()) do
		local name=getDisplayName(obj.Name)
		local icon,col
		if isRainbow(obj.Name) then         icon="🌈"; col="#FF80FF"
		elseif isViolet(obj.Name) then      icon="💜"; col="#CC88FF"
		elseif isSquirm(obj.Name) then      icon="✨"; col="#FFE066"
		else                                icon="👾"; col="#FF5555" end
		table.insert(lines,'<font color="'..col..'">'..icon..' '..name..'</font>')
	end
	monitorLabel.Text=table.concat(lines,"\n")
end

