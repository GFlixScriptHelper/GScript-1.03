        elseif isGuidePink(m.name) then
            stroke.Color = Color3.fromRGB(255, 105, 180)
            table.insert(pinkCards, stroke)
        elseif isGuideSquirm(m.name) then
            stroke.Color = Color3.fromRGB(255, 140, 0)
