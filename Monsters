local notifyEnabled   = false
local activePopups    = {}  -- list of popup frames currently on screen
local MAX_POPUPS      = 5
local POPUP_W         = 160
local POPUP_H         = 70
local POPUP_PADDING   = 8
local POPUP_X_SHOWN   = 1  -- scale X when visible (anchored right)
local POPUP_X_HIDDEN  = 1  -- pushed off right
local POPUP_OFFSET_X_SHOWN  = -(POPUP_W + 8)
local POPUP_OFFSET_X_HIDDEN = 20

-- Build headshot ID lookup from MONSTER_GUIDE
local HEADSHOT_IDS = {}
for _, m in ipairs(MONSTER_GUIDE) do
    HEADSHOT_IDS[m.name:lower()] = m.id
end

local function getHeadshotId(monsterObjName)
    -- Strip "Twisted" prefix and try to match
    local stripped = monsterObjName:lower()
                        :gsub("twisted","")
                        :gsub("^%s+","")
                        :gsub("%s+$","")
    for k, v in pairs(HEADSHOT_IDS) do
        if k:lower():find(stripped) or stripped:find(k:lower()) then
            return v
        end
    end
    return "rbxassetid://0"
end

local function getPopupBaseY()
    -- Bottom anchor offset for bottom-most popup
    return -(POPUP_H + 12)
end

local function repositionPopups()
    -- Stack upward from bottom-right
    for i, popup in ipairs(activePopups) do
        local idx    = #activePopups - i  -- 0 = bottom, higher = up
        local yOff   = getPopupBaseY() - idx * (POPUP_H + POPUP_PADDING)
        TweenService:Create(popup, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(POPUP_X_SHOWN, POPUP_OFFSET_X_SHOWN, 1, yOff),
        }):Play()
    end
end

local function dismissPopup(popup)
    -- Slide out to the right
    local t = TweenService:Create(popup, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = UDim2.new(POPUP_X_HIDDEN, POPUP_OFFSET_X_HIDDEN, popup.Position.Y.Scale, popup.Position.Y.Offset),
    })
    t:Play()
    t.Completed:Connect(function()
        popup:Destroy()
    end)
    -- Remove from table
    for i, p in ipairs(activePopups) do
        if p == popup then table.remove(activePopups, i); break end
    end
end

