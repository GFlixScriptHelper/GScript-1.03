	local l=Instance.new("TextLabel")
	l.Size=UDim2.new(1,-14,1,0); l.Position=UDim2.new(0,12,0,0)
	l.BackgroundTransparency=1; l.Text=txt
	l.TextColor3=Color3.fromRGB(160,170,220); l.Font=Enum.Font.FredokaOne
	l.TextSize=12; l.TextXAlignment=Enum.TextXAlignment.Left; l.Parent=f
end

local function makeBtn(parent, txt, color, order, fn)
	local b=Instance.new("TextButton")
	b.Size=UDim2.new(1,-4,0,34); b.BackgroundColor3=color
	b.TextColor3=WHITE; b.Font=Enum.Font.FredokaOne
	b.TextSize=12; b.Text=txt; b.BorderSizePixel=0
	b.AutoButtonColor=false; b.LayoutOrder=order; b.Parent=parent
	makeCorner(b,8); makeStroke(b,Color3.fromRGB(80,80,120),1,0.4)
	local grad=Instance.new("UIGradient"); grad.Rotation=90
	grad.Transparency=NumberSequence.new({
		NumberSequenceKeypoint.new(0,0.1), NumberSequenceKeypoint.new(1,0.3)
	}); grad.Parent=b
	b.MouseButton1Click:Connect(function() pcall(fn) end)
	return b
end

