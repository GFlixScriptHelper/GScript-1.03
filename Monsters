-- Headshot lookup from MONSTER_GUIDE (built later, safe to use after it's defined)
local function getHeadshotForObj(objName)
    local stripped = objName:lower():gsub("twisted",""):gsub("^%s+",""):gsub("%s+$","")
    for _, m in ipairs(MONSTER_GUIDE) do
        if m.name:lower():find(stripped) or stripped:find(m.name:lower()) then
            return m.id
        end
    end
    return "0"
end

-- Rebuild monster detector cards based on current map
local function rebuildMonsterDetector()
    if not monsterDetectorSF then return end
    -- Clear old cards
    for _, c in ipairs(monsterDetectorSF:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end
    local map = getMap()
    if not map then return end
    local mf = map:FindFirstChild("Monsters")
    if not mf then return end

    local GUIDE_RAINBOW = {"Astro","Shelly","Vee","Dandy","Dyle","Sprout","Pebble"}
    local GUIDE_PINK    = {"Bassie","Flyte","Cocoa","Eggson"}
    local GUIDE_SQUIRM  = {"Squirm"}
    local function isGRainbow(n) for _,k in ipairs(GUIDE_RAINBOW) do if n:lower():find(k:lower()) then return true end end return false end
    local function isGPink(n)    for _,k in ipairs(GUIDE_PINK)    do if n:lower():find(k:lower()) then return true end end return false end
    local function isGSquirm(n)  for _,k in ipairs(GUIDE_SQUIRM)  do if n:lower():find(k:lower()) then return true end end return false end

    local rainbowStrokes = {}
    local pinkStrokes    = {}
    local squirmStrokes  = {}

    for i, obj in ipairs(mf:GetChildren()) do
        local card = Instance.new("Frame")
        card.Size             = UDim2.new(0, 80, 0, 100)
        card.BackgroundColor3 = Color3.fromRGB(22, 24, 40)
        card.BorderSizePixel  = 0
        card.LayoutOrder      = i
        card.Parent           = monsterDetectorSF
        makeCorner(card, 6)

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 1.5; stroke.Transparency = 0; stroke.Parent = card
        if isGRainbow(obj.Name) then stroke.Color=Color3.fromRGB(255,0,0); table.insert(rainbowStrokes,stroke)
        elseif isGPink(obj.Name) then stroke.Color=Color3.fromRGB(255,105,180); table.insert(pinkStrokes,stroke)
        elseif isGSquirm(obj.Name) then stroke.Color=Color3.fromRGB(255,140,0); table.insert(squirmStrokes,stroke)
        else stroke.Color=Color3.fromRGB(55,55,85) end

        local img = Instance.new("ImageLabel")
        img.Size=UDim2.new(1,-8,0,70); img.Position=UDim2.new(0,4,0,4)
        img.BackgroundColor3=Color3.fromRGB(14,14,22); img.BorderSizePixel=0
        img.Image="rbxassetid://"..getHeadshotForObj(obj.Name)
        img.ScaleType=Enum.ScaleType.Fit; img.Parent=card; makeCorner(img,4)

        local lbl = Instance.new("TextLabel")
        lbl.Size=UDim2.new(1,-4,0,24); lbl.Position=UDim2.new(0,2,1,-26)
        lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.FredokaOne; lbl.TextSize=9
        lbl.TextColor3=Color3.fromRGB(200,210,240); lbl.TextWrapped=true
        lbl.TextXAlignment=Enum.TextXAlignment.Center; lbl.TextScaled=false
        lbl.Text=getDisplayName(obj.Name):gsub("Twisted ",""); lbl.Parent=card
    end

    -- Animate strokes
    local rT,pT=0,0
    RunService.Heartbeat:Connect(function(dt)
        if not monsterDetectorSF or not monsterDetectorSF.Parent then return end
        rT=(rT+dt*1.5)%1; pT=(pT+dt*1.2)%1
        if #rainbowStrokes>0 then
            local col=Color3.fromHSV(rT,1,1)
            for _,s in ipairs(rainbowStrokes) do pcall(function() s.Color=col end) end
        end
        if #pinkStrokes>0 then
            local t=math.abs(math.sin(pT*math.pi))
            local col=Color3.fromRGB(255,105,180):Lerp(Color3.fromRGB(255,255,255),t)
            for _,s in ipairs(pinkStrokes) do pcall(function() s.Color=col end) end
        end
        if #squirmStrokes>0 then
            local t=math.abs(math.sin(pT*math.pi))
            local col=Color3.fromRGB(255,140,0):Lerp(Color3.fromRGB(255,255,255),t)
            for _,s in ipairs(squirmStrokes) do pcall(function() s.Color=col end) end
        end
    end)
end

