local slBtn  = makeFloatBtn("🔒",Color3.fromRGB(40,80,180),  10,200)
local flipL  = makeFloatBtn("L", Color3.fromRGB(120,40,180), 10,265)
local flipK  = makeFloatBtn("K", Color3.fromRGB(120,40,180), 10,330)
local flipJ  = makeFloatBtn("J", Color3.fromRGB(120,40,180), 10,395)
local tpBtn  = makeFloatBtn("TP",Color3.fromRGB(40,140,180), 10,460)

local function applyBtnSize()
    for _,b in ipairs(allMobileBtns) do
        b.Size=UDim2.new(0,btnSize,0,btnSize)
        local c=b:FindFirstChildOfClass("UICorner")
        if c then c.CornerRadius=UDim.new(0,math.floor(btnSize/2)) end
    end
end

-- ============================================================
--  SHIFTLOCK
-- ============================================================
local function setShiftLock(on)
    shiftLockActive=on
    if on then
        slBtn.BackgroundColor3=Color3.fromRGB(30,180,80); slBtn.Text="🔓"
        shiftLockConn=RunService.RenderStepped:Connect(function()
            local char=player.Character; if not char then return end
            local root=char:FindFirstChild("HumanoidRootPart"); if not root then return end
            local _,camY=workspace.CurrentCamera.CFrame:ToOrientation()
            root.CFrame=CFrame.new(root.Position)*CFrame.fromOrientation(0,camY,0)
            UserInputSvc.MouseBehavior=Enum.MouseBehavior.LockCenter
        end)
    else
        slBtn.BackgroundColor3=Color3.fromRGB(40,80,180); slBtn.Text="🔒"
        if shiftLockConn then shiftLockConn:Disconnect(); shiftLockConn=nil end
        UserInputSvc.MouseBehavior=Enum.MouseBehavior.Default
    end
end

slBtn.MouseButton1Click:Connect(function() setShiftLock(not shiftLockActive) end)

-- ============================================================
--  FLIP FUNCTIONS
-- ============================================================
local h=0.0174533

local function doFrontflip()
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    local hrp=char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp or hum:GetState()==Enum.HumanoidStateType.Dead then return end
    hum:ChangeState("Jumping"); task.wait(); hum.Sit=true
    for i=1,360 do
        task.delay(i/720,function()
            if hum and hrp and hum.Parent then
                hum.Sit=true; hrp.CFrame=hrp.CFrame*CFrame.Angles(-h,0,0) end end)
    end
    task.wait(0.55); if hum and hum.Parent then hum.Sit=false end
end

local function doBackflip()
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    local hrp=char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp or hum:GetState()==Enum.HumanoidStateType.Dead then return end
    hum:ChangeState("Jumping"); task.wait(); hum.Sit=true
    for i=1,360 do
        task.delay(i/720,function()
            if hum and hrp and hum.Parent then
                hum.Sit=true; hrp.CFrame=hrp.CFrame*CFrame.Angles(h,0,0) end end)
    end
    task.wait(0.55); if hum and hum.Parent then hum.Sit=false end
end

local function doAirjump()
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hum or hum:GetState()==Enum.HumanoidStateType.Dead then return end
    hum:ChangeState("Seated"); task.wait(); hum:ChangeState("Jumping")
end

local ContextActionSvc=game:GetService("ContextActionService")
ContextActionSvc:BindAction("ESP_Frontflip",function(_,state)
    if state==Enum.UserInputState.Begin then task.spawn(doFrontflip) end
end,false,Enum.KeyCode.L)
ContextActionSvc:BindAction("ESP_Backflip",function(_,state)
    if state==Enum.UserInputState.Begin then task.spawn(doBackflip) end
end,false,Enum.KeyCode.K)
ContextActionSvc:BindAction("ESP_Airjump",function(_,state)
    if state==Enum.UserInputState.Begin then task.spawn(doAirjump) end
end,false,Enum.KeyCode.J)

flipL.MouseButton1Click:Connect(function() task.spawn(doFrontflip) end)
flipK.MouseButton1Click:Connect(function() task.spawn(doBackflip)  end)
flipJ.MouseButton1Click:Connect(function() task.spawn(doAirjump)   end)

tpBtn.MouseButton1Click:Connect(function()
    if tpwalkActive then
        stopTpwalk()
        tpBtn.BackgroundColor3=Color3.fromRGB(40,140,180); tpBtn.Text="TP"
    else
        startTpwalk()
        tpBtn.BackgroundColor3=Color3.fromRGB(20,180,100); tpBtn.Text="TP ✓"
    end
end)

