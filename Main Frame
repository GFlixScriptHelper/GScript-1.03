local function playIntro()
    local fadeInDuration  = 1.2
    local fadeOutDuration = 1.2
    local totalDuration   = fadeInDuration + fadeOutDuration
    local startSize = 20
    local endSize   = 220
    local rotation  = 0
    local elapsed   = 0
    local done      = false

    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if done then return end
        elapsed = elapsed + dt

        local zoomT = math.clamp(elapsed / totalDuration, 0, 1)
        local currentSize = startSize + (endSize - startSize) * zoomT
        IntroIcon.Size = UDim2.new(0, currentSize, 0, currentSize)

        rotation = (rotation + 200 * dt) % 360
        RainbowGradient.Rotation = rotation

        if elapsed <= fadeInDuration then
            IntroIcon.ImageTransparency = 1 - (elapsed / fadeInDuration)
        elseif elapsed <= totalDuration then
            IntroIcon.ImageTransparency = (elapsed - fadeInDuration) / fadeOutDuration
        else
            done = true
            conn:Disconnect()
            IntroIcon:Destroy()

            -- Pop in toggle button
            ToggleButton.Visible = true
            local popOut = TweenService:Create(ToggleButton,
                TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 85, 0, 85),
            })
            popOut:Play()
            popOut.Completed:Wait()
            TweenService:Create(ToggleButton,
                TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 75, 0, 75),
            }):Play()
        end
    end)
end

