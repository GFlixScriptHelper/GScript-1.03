-- ============================================================
--  TAB SWITCHING LOGIC
-- ============================================================
local function switchTab(index)
    -- Deactivate all
    for i, btn in ipairs(tabButtons) do
        local stroke = btn:FindFirstChildOfClass("UIStroke")
        if stroke then stroke:Destroy() end
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(20,22,35),
            TextColor3       = Color3.fromRGB(140,145,170),
        }):Play()
        tabScrollFrames[i].Visible = false
    end

    -- Activate selected
    local btn = tabButtons[index]
    TweenService:Create(btn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(40,45,75),
        TextColor3       = WHITE,
    }):Play()
    makeStroke(btn, Color3.fromRGB(100,120,255), 1, 0)
    tabScrollFrames[index].Visible = true
    activeTab = index

    -- Load tab script if not yet loaded (skip Main Menu = index 1)
    if index > 1 and not loadedTabs[index] then
        loadedTabs[index] = true
        local url = TAB_URLS[index].url
        if url then
            task.spawn(function()
                local ok, result = pcall(function()
                    return game:HttpGet(url)
                end)
                if ok and result then
                    local fn, err = loadstring(result)
                    if fn then
                        local runOk, runErr = pcall(fn)
                        if not runOk then
                            warn("[GScript] Tab '"..TAB_URLS[index].name.."' runtime error: "..tostring(runErr))
                        end
                    else
                        warn("[GScript] Tab '"..TAB_URLS[index].name.."' parse error: "..tostring(err))
                    end
                else
                    warn("[GScript] Failed to load tab '"..TAB_URLS[index].name.."': "..tostring(result))
                end
            end)
        end
    end
end

for i, btn in ipairs(tabButtons) do
    btn.MouseButton1Click:Connect(function()
        switchTab(i)
    end)
end

