local function makeCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
end

local function makeStroke(p, col, th, trans)
    local s = Instance.new("UIStroke")
    s.Color       = col or Color3.fromRGB(60, 60, 90)
    s.Thickness   = th or 1
    s.Transparency = trans or 0
    s.Parent = p
end

local function makeHeader(txt, order)
    if not scrollFrame then return end

    local f = Instance.new("Frame")
    f.Size             = UDim2.new(1, -4, 0, 24)
    f.BackgroundTransparency = 1
    f.LayoutOrder      = order
    f.Parent           = scrollFrame

    local accent = Instance.new("Frame")
    accent.Size             = UDim2.new(0, 3, 0, 14)
    accent.Position         = UDim2.new(0, 2, 0.5, -7)
    accent.BackgroundColor3 = Color3.fromRGB(100, 120, 255)
    accent.BorderSizePixel  = 0
    accent.Parent           = f
    makeCorner(accent, 2)

    local l = Instance.new("TextLabel")
    l.Size             = UDim2.new(1, -14, 1, 0)
    l.Position         = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Text             = txt
    l.TextColor3       = Color3.fromRGB(160, 170, 220)
    l.Font             = Enum.Font.FredokaOne
    l.TextSize         = 12
    l.TextXAlignment   = Enum.TextXAlignment.Left
    l.Parent           = f
end

local function makeToggleRow(labelTxt, pillColor, order, onToggle)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, -4, 0, 38)
    row.BackgroundColor3 = Color3.fromRGB(18, 20, 34)
    row.BorderSizePixel  = 0
    row.LayoutOrder      = order
    if not scrollFrame then return nil, nil end
    row.Parent           = scrollFrame
    makeCorner(row, 8)
    makeStroke(row, Color3.fromRGB(45, 45, 70), 1, 0)

    local pill = Instance.new("Frame")
    pill.Size             = UDim2.new(0, 5, 0, 18)
    pill.Position         = UDim2.new(0, 9, 0.5, -9)
    pill.BackgroundColor3 = pillColor
    pill.BorderSizePixel  = 0
    pill.Parent           = row
    makeCorner(pill, 3)

    local lbl = Instance.new("TextLabel")
    lbl.Size             = UDim2.new(1, -70, 1, 0)
    lbl.Position         = UDim2.new(0, 20, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text             = labelTxt
    lbl.TextColor3       = Color3.fromRGB(210, 215, 235)
    lbl.Font             = Enum.Font.FredokaOne
    lbl.TextSize         = 12
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.Parent           = row

    local swBg = Instance.new("TextButton")
    swBg.Size             = UDim2.new(0, 44, 0, 22)
    swBg.Position         = UDim2.new(1, -52, 0.5, -11)
    swBg.BackgroundColor3 = Color3.fromRGB(40, 40, 65)
    swBg.BorderSizePixel  = 0
    swBg.Text             = ""
    swBg.AutoButtonColor  = false
    swBg.Parent           = row
    makeCorner(swBg, 11)
    makeStroke(swBg, Color3.fromRGB(60, 60, 90), 1, 0)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(140, 140, 170)
    knob.BorderSizePixel  = 0
    knob.Parent           = swBg
    makeCorner(knob, 8)

    local enabled = false
    local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local function refresh()
        if enabled then
            TweenService:Create(swBg,  tweenInfo, {BackgroundColor3 = Color3.fromRGB(60,160,255)}):Play()
            TweenService:Create(knob,  tweenInfo, {Position = UDim2.new(0,25,0.5,-8), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
            TweenService:Create(row,   tweenInfo, {BackgroundColor3 = Color3.fromRGB(16,26,48)}):Play()
        else
            TweenService:Create(swBg,  tweenInfo, {BackgroundColor3 = Color3.fromRGB(40,40,65)}):Play()
            TweenService:Create(knob,  tweenInfo, {Position = UDim2.new(0,3,0.5,-8), BackgroundColor3 = Color3.fromRGB(140,140,170)}):Play()
            TweenService:Create(row,   tweenInfo, {BackgroundColor3 = Color3.fromRGB(18,20,34)}):Play()
        end
    end

    swBg.MouseButton1Click:Connect(function()
        enabled = not enabled
        refresh()
        onToggle(enabled, pill)
    end)

    refresh()
    return row, pill
end

