local lastCheck=0
RunService.Heartbeat:Connect(function(dt)
    rainbowTime=(rainbowTime+dt*1.5)%1
    squirmTime=(squirmTime+dt*1.2)%1
    if #rainbowRegistry>0 then
        local col=Color3.fromHSV(rainbowTime,1,1)
        for _,hl in ipairs(rainbowRegistry) do pcall(function() hl.FillColor=col; hl.OutlineColor=col end) end
    end
    if #squirmRegistry>0 then
        local t=math.abs(math.sin(squirmTime*math.pi))
        local col=Color3.fromRGB(255,140,0):Lerp(Color3.fromRGB(255,255,255),t)
        for _,hl in ipairs(squirmRegistry) do pcall(function() hl.FillColor=col; hl.OutlineColor=col end) end
    end
    if #holidayRegistry>0 then
        local t=math.abs(math.sin(squirmTime*math.pi))
        local col=Color3.fromRGB(255,105,180):Lerp(Color3.fromRGB(255,255,255),t)
        for _,hl in ipairs(holidayRegistry) do pcall(function() hl.FillColor=col; hl.OutlineColor=col end) end
    end
    lastCheck=lastCheck+dt
    if lastCheck<2 then return end
    lastCheck=0
    if not currentMap then return end
    for _, e in ipairs(ESP_ENTRIES) do
        if e.enabled then
            local alive=0
            for _,h in ipairs(e.highlights) do if h and h.Parent then alive=alive+1 end end
            if alive==0 then applyEntry(e) end
        end
    end
end)

