local generatorBillboards = {}

local function clearGeneratorBillboards()
    for _, bb in ipairs(generatorBillboards) do
        pcall(function() bb:Destroy() end)
    end
    generatorBillboards = {}
end

local function getGenColor(current, required)
    if required <= 0 then return Color3.fromRGB(220,40,40) end
    local pct = current / required
    if pct <= 0 then       return Color3.fromRGB(220,40,40)
    elseif pct < 0.33 then return Color3.fromRGB(255,120,0)
    elseif pct < 0.66 then return Color3.fromRGB(255,220,0)
    else                   return Color3.fromRGB(40,200,80) end
end

local function addGeneratorBillboard(obj, hl)
    local stats = obj:FindFirstChild("Stats")
    if not stats then return end
    local curVal = stats:FindFirstChild("CurrentAmount")
    local reqVal = stats:FindFirstChild("RequiredAmount")
    if not curVal or not reqVal then return end
    local old = obj:FindFirstChild("ESP_GenLabel")
    if old then old:Destroy() end
    local bb = Instance.new("BillboardGui")
    bb.Name="ESP_GenLabel"; bb.Size=UDim2.new(0,160,0,56)
    bb.StudsOffset=Vector3.new(0,2.5,0); bb.AlwaysOnTop=true
    bb.LightInfluence=0; bb.Adornee=obj; bb.Parent=obj
    local layout = Instance.new("UIListLayout")
    layout.SortOrder=Enum.SortOrder.LayoutOrder; layout.Padding=UDim.new(0,1)
    layout.HorizontalAlignment=Enum.HorizontalAlignment.Center; layout.Parent=bb
    local userLbl = Instance.new("TextLabel")
    userLbl.Size=UDim2.new(1,0,0,16); userLbl.BackgroundTransparency=1; userLbl.Text=""
    userLbl.TextColor3=Color3.fromRGB(180,220,255); userLbl.Font=Enum.Font.FredokaOne
    userLbl.TextSize=11; userLbl.TextStrokeTransparency=0
    userLbl.TextStrokeColor3=Color3.fromRGB(0,0,0); userLbl.TextWrapped=true
    userLbl.LayoutOrder=1; userLbl.Parent=bb
    local progLbl = Instance.new("TextLabel")
    progLbl.Size=UDim2.new(1,0,0,22); progLbl.BackgroundTransparency=1
    progLbl.Text=tostring(math.floor(curVal.Value)).."/"..tostring(math.floor(reqVal.Value))
    progLbl.TextColor3=getGenColor(curVal.Value,reqVal.Value); progLbl.Font=Enum.Font.FredokaOne
    progLbl.TextSize=17; progLbl.TextStrokeTransparency=0
    progLbl.TextStrokeColor3=Color3.fromRGB(0,0,0); progLbl.LayoutOrder=2; progLbl.Parent=bb
    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size=UDim2.new(1,0,0,14); nameLbl.BackgroundTransparency=1
    nameLbl.Text="⚙ "..obj.Name; nameLbl.TextColor3=Color3.fromRGB(160,160,160)
    nameLbl.Font=Enum.Font.FredokaOne; nameLbl.TextSize=11; nameLbl.TextStrokeTransparency=0
    nameLbl.TextStrokeColor3=Color3.fromRGB(0,0,0); nameLbl.LayoutOrder=3; nameLbl.Parent=bb
    table.insert(generatorBillboards, bb)
    local function updateUsers()
        local pc = obj:FindFirstChild("PlayerCompletion")
        if not pc then userLbl.Text=""; return end
        local names = {}
        for _, v in ipairs(pc:GetChildren()) do
            if v:IsA("NumberValue") then table.insert(names, v.Name) end
        end
        if #names==0 then userLbl.Text=""
        elseif #names==1 then userLbl.Text="👤 "..names[1]
        else userLbl.Text="👥 "..table.concat(names,", ") end
    end
    local tweenInfo2 = TweenInfo.new(0.5,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
    local activeTween = nil
    local function updateProgress()
        local cur=curVal.Value; local req=reqVal.Value
        local col=getGenColor(cur,req)
        progLbl.Text=tostring(math.floor(cur)).."/"..tostring(math.floor(req))
        if activeTween then pcall(function() activeTween:Cancel() end) end
        TweenService:Create(progLbl,tweenInfo2,{TextColor3=col}):Play()
        if hl and hl.Parent then
            activeTween=TweenService:Create(hl,tweenInfo2,{OutlineColor=col}); activeTween:Play()
        else activeTween=nil end
    end
    curVal:GetPropertyChangedSignal("Value"):Connect(function() pcall(updateProgress) end)
    reqVal:GetPropertyChangedSignal("Value"):Connect(function() pcall(updateProgress) end)
    local pc=obj:FindFirstChild("PlayerCompletion")
    if pc then
        pc.ChildAdded:Connect(function() task.wait(0.05); pcall(updateUsers) end)
        pc.ChildRemoved:Connect(function() task.wait(0.05); pcall(updateUsers) end)
    end
    obj.ChildAdded:Connect(function(child)
        if child.Name=="PlayerCompletion" then
            task.wait(0.05); pcall(updateUsers)
            child.ChildAdded:Connect(function() task.wait(0.05); pcall(updateUsers) end)
            child.ChildRemoved:Connect(function() task.wait(0.05); pcall(updateUsers) end)
        end
    end)
    updateProgress(); updateUsers()
end

local function clearEntry(e)
    for _, h in ipairs(e.highlights) do
        pcall(function() h:Destroy() end)
        for i=#rainbowRegistry,1,-1 do if rainbowRegistry[i]==h then table.remove(rainbowRegistry,i); break end end
        for i=#squirmRegistry,1,-1  do if squirmRegistry[i]==h  then table.remove(squirmRegistry,i);  break end end
        for i=#holidayRegistry,1,-1 do if holidayRegistry[i]==h then table.remove(holidayRegistry,i); break end end
    end
    e.highlights={}
    if e.match=="ResearchCapsule" then clearResearchLabels() end
    if e.folder=="Generators"     then clearGeneratorBillboards() end
end

local function applyEntry(e)
    clearEntry(e)
    if not e.enabled or not currentMap then return end
    local folder=currentMap:FindFirstChild(e.folder)
    if not folder then return end
    for _, obj in ipairs(folder:GetChildren()) do
        local match=(e.match==nil) or obj.Name:lower():find(e.match:lower())
        if match then
            local hl=Instance.new("Highlight")
            hl.FillTransparency=0.5; hl.OutlineTransparency=0
            if e.folder=="Monsters" and isSquirm(obj.Name) then
                hl.FillColor=Color3.fromRGB(255,140,0); hl.OutlineColor=Color3.fromRGB(255,140,0)
                table.insert(squirmRegistry,hl)
            elseif e.folder=="Monsters" and isRainbow(obj.Name) then
                hl.FillColor=Color3.fromRGB(255,0,0); hl.OutlineColor=Color3.fromRGB(255,0,0)
                table.insert(rainbowRegistry,hl)
            elseif e.match=="HolidayCollectibleItem" then
                hl.FillColor=Color3.fromRGB(255,105,180); hl.OutlineColor=Color3.fromRGB(255,105,180)
                table.insert(holidayRegistry,hl)
            else
                if e.folder=="Generators" then
                    local stats=obj:FindFirstChild("Stats")
                    local curVal=stats and stats:FindFirstChild("CurrentAmount")
                    local reqVal=stats and stats:FindFirstChild("RequiredAmount")
                    local cur=curVal and curVal.Value or 0
                    local req=reqVal and reqVal.Value or 1
                    hl.FillColor=Color3.fromRGB(255,255,255); hl.FillTransparency=0.6
                    hl.OutlineColor=getGenColor(cur,req)
                else
                    hl.FillColor=e.color; hl.OutlineColor=e.color
                end
            end
            hl.Adornee=obj; hl.Parent=hlFolder
            table.insert(e.highlights,hl)
            if e.match=="ResearchCapsule" then addResearchLabel(obj) end
            if e.folder=="Generators"     then addGeneratorBillboard(obj,hl) end
        end
    end
end

local function refreshAll()
    for _, e in ipairs(ESP_ENTRIES) do applyEntry(e) end
end

-- ============================================================
--  MAP WATCHER
-- ============================================================
local function onMapArrived(child)
    task.wait(0.3)
    if not child or not child.Parent then return end
    currentMap=child
    local elapsed=0
    repeat
        if not child.Parent or currentMap~=child then return end
        refreshAll(); task.wait(0.5); elapsed=elapsed+0.5
    until elapsed>=10
end

local function watchCurrentRoom()
    local cr=workspace:FindFirstChild("CurrentRoom") or workspace:WaitForChild("CurrentRoom",30)
    if not cr then return end
    cr.ChildAdded:Connect(function(child)
        if child:IsA("Model") then task.spawn(onMapArrived,child) end
    end)
    cr.ChildRemoved:Connect(function()
        currentMap=nil
        for _, e in ipairs(ESP_ENTRIES) do clearEntry(e) end
    end)
    for _, child in ipairs(cr:GetChildren()) do
        if child:IsA("Model") then task.spawn(onMapArrived,child); break end
    end
end

