local function addResearchLabel(obj)
    local prompt = obj:FindFirstChild("Prompt", true)
    if not prompt then
        task.delay(1, function()
            if not obj or not obj.Parent then return end
            prompt = obj:FindFirstChild("Prompt", true)
            if not prompt then return end
            local monsterVal = prompt:FindFirstChild("Monster")
            if not monsterVal or not monsterVal:IsA("StringValue") then return end
            local rawName = monsterVal.Value
            if rawName == "" then monsterVal.Changed:Wait(); rawName = monsterVal.Value end
            local displayName = rawName:gsub("[Mm]onster$",""):gsub("^%s+",""):gsub("%s+$","")
            if displayName == "" then displayName = rawName end
            local existing = obj:FindFirstChild("ESP_ResearchLabel")
            if existing then existing:Destroy() end
            local bb = Instance.new("BillboardGui")
            bb.Name="ESP_ResearchLabel"; bb.Size=UDim2.new(0,100,0,24)
            bb.StudsOffset=Vector3.new(0,4,0); bb.AlwaysOnTop=true
            bb.LightInfluence=0; bb.Adornee=obj; bb.Parent=obj
            local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0)
            lbl.BackgroundTransparency=1; lbl.Text=displayName
            lbl.TextColor3=Color3.fromRGB(255,80,200); lbl.Font=Enum.Font.FredokaOne
            lbl.TextSize=14; lbl.TextStrokeTransparency=0
            lbl.TextStrokeColor3=Color3.fromRGB(0,0,0); lbl.Parent=bb
            table.insert(researchBillboards, bb)
        end)
        return
    end

    local monsterVal = prompt:FindFirstChild("Monster")
    if not monsterVal or not monsterVal:IsA("StringValue") then return end
    local rawName = monsterVal.Value
    if rawName == "" then
        task.delay(1.5, function()
            if not obj or not obj.Parent then return end
            rawName = monsterVal.Value
            if rawName == "" then return end
            local displayName = rawName:gsub("[Mm]onster$",""):gsub("^%s+",""):gsub("%s+$","")
            if displayName == "" then displayName = rawName end
            local existing = obj:FindFirstChild("ESP_ResearchLabel")
            if existing then existing:Destroy() end
            local bb = Instance.new("BillboardGui")
            bb.Name="ESP_ResearchLabel"; bb.Size=UDim2.new(0,100,0,24)
            bb.StudsOffset=Vector3.new(0,4,0); bb.AlwaysOnTop=true
            bb.LightInfluence=0; bb.Adornee=obj; bb.Parent=obj
            local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0)
            lbl.BackgroundTransparency=1; lbl.Text=displayName
            lbl.TextColor3=Color3.fromRGB(255,80,200); lbl.Font=Enum.Font.FredokaOne
            lbl.TextSize=14; lbl.TextStrokeTransparency=0
            lbl.TextStrokeColor3=Color3.fromRGB(0,0,0); lbl.Parent=bb
            table.insert(researchBillboards, bb)
        end)
        return
    end

    local displayName = rawName:gsub("[Mm]onster$",""):gsub("^%s+",""):gsub("%s+$","")
    if displayName == "" then displayName = rawName end
    local existing = obj:FindFirstChild("ESP_ResearchLabel")
    if existing then existing:Destroy() end
    local bb = Instance.new("BillboardGui")
    bb.Name="ESP_ResearchLabel"; bb.Size=UDim2.new(0,100,0,24)
    bb.StudsOffset=Vector3.new(0,4,0); bb.AlwaysOnTop=true
    bb.LightInfluence=0; bb.Adornee=obj; bb.Parent=obj
    local lbl = Instance.new("TextLabel")
    lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
    lbl.Text=displayName; lbl.TextColor3=Color3.fromRGB(255,80,200)
    lbl.Font=Enum.Font.FredokaOne; lbl.TextSize=14
    lbl.TextStrokeTransparency=0; lbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    lbl.Parent=bb
    table.insert(researchBillboards, bb)
    monsterVal.Changed:Connect(function(newVal)
        if not bb or not bb.Parent then return end
