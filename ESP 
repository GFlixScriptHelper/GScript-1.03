local function isRainbow(name)
    local l = name:lower()
    for _, k in ipairs(RAINBOW_MONSTERS) do if l:find(k:lower()) then return true end end
    return false
end
local function isSquirm(name)
    local l = name:lower()
    for _, k in ipairs(SQUIRM_KEYWORDS) do if l:find(k:lower()) then return true end end
    return false
end

