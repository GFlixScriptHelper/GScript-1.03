    hpLbl.TextColor3=getHealthColor(hum.Health,hum.MaxHealth)
    hpLbl.Font=Enum.Font.FredokaOne; hpLbl.TextSize=13
    hpLbl.TextStrokeTransparency=0; hpLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    hpLbl.LayoutOrder=3; hpLbl.Parent=bb
    playerData[p]={highlight=hl,billboard=bb,hpLbl=hpLbl,hl=hl,hum=hum}
    hum:GetPropertyChangedSignal("Health"):Connect(function()
        if not playerESPOn or not playerData[p] then return end
        local col=getHealthColor(hum.Health,hum.MaxHealth)
        hl.OutlineColor=col; hpLbl.TextColor3=col
        hpLbl.Text=getHearts(hum.Health,hum.MaxHealth)
    end)
end

local function enablePlayerESP()
    playerESPOn=true
    for _,p in ipairs(Players:GetPlayers()) do applyPlayerESP(p) end
    Players.PlayerAdded:Connect(function(p)
        if not playerESPOn then return end
        p.CharacterAdded:Connect(function() task.wait(0.5); applyPlayerESP(p) end)
    end)
    Players.PlayerRemoving:Connect(function(p) clearPlayerESP(p) end)
    for _,p in ipairs(Players:GetPlayers()) do
        p.CharacterAdded:Connect(function() task.wait(0.5); applyPlayerESP(p) end)
    end
end

local function disablePlayerESP()
    playerESPOn=false
    for p,_ in pairs(playerData) do clearPlayerESP(p) end
    playerData={}
end

