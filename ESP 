local localPlayer=Players.LocalPlayer
local playerESPOn=false
local playerData={}

local function getHealthColor(hp, maxHp)
    if maxHp>=4 then
        if hp>=4 then return Color3.fromRGB(100,210,255)
        elseif hp>=3 then return Color3.fromRGB(40,200,80)
        elseif hp>=2 then return Color3.fromRGB(255,140,0)
        else return Color3.fromRGB(220,40,40) end
    elseif maxHp==3 then
        if hp>=3 then return Color3.fromRGB(40,200,80)
        elseif hp>=2 then return Color3.fromRGB(255,140,0)
        else return Color3.fromRGB(220,40,40) end
    else
        if hp>=2 then return Color3.fromRGB(40,200,80)
        else return Color3.fromRGB(220,40,40) end
    end
end

local function getHearts(hp, maxHp)
    local full=math.max(0,math.floor(hp))
    local empty=math.max(0,maxHp-full)
    return string.rep("❤️",full)..string.rep("🖤",empty)
end

local function clearPlayerESP(p)
    if playerData[p] then
        pcall(function() playerData[p].highlight:Destroy() end)
        pcall(function() playerData[p].billboard:Destroy() end)
        playerData[p]=nil
    end
end

local function applyPlayerESP(p)
    if p==localPlayer then return end
    clearPlayerESP(p)
    if not playerESPOn then return end
    local char=p.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end
    local hl=Instance.new("Highlight")
    hl.FillTransparency=1; hl.OutlineTransparency=0
    hl.OutlineColor=getHealthColor(hum.Health,hum.MaxHealth)
    hl.Adornee=char; hl.Parent=hlFolder
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local bb=Instance.new("BillboardGui")
