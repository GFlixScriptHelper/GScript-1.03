    userLbl.Font=Enum.Font.FredokaOne; userLbl.TextSize=11
    userLbl.TextStrokeTransparency=0; userLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    userLbl.LayoutOrder=1; userLbl.Parent=bb
    local dispLbl=Instance.new("TextLabel")
    dispLbl.Size=UDim2.new(1,0,0,22); dispLbl.BackgroundTransparency=1
    dispLbl.Text=p.DisplayName; dispLbl.TextColor3=Color3.fromRGB(255,255,255)
    dispLbl.Font=Enum.Font.FredokaOne; dispLbl.TextSize=17
    dispLbl.TextStrokeTransparency=0; dispLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
