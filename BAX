    pcall(function()
        local ex=CoreGui:FindFirstChild("BaxMsgGui")
        if ex then ex:Destroy() end
        local jGui=Instance.new("ScreenGui")
        jGui.Name="BaxMsgGui"; jGui.ResetOnSpawn=false
        jGui.DisplayOrder=9998; jGui.IgnoreGuiInset=true; jGui.Parent=CoreGui
        local jf=Instance.new("Frame")
        jf.Size=UDim2.new(0,300,0,65)
        jf.Position=UDim2.new(0.5,-150,1,10)
        jf.BackgroundColor3=Color3.fromRGB(18,18,26)
        jf.BorderSizePixel=0; jf.Parent=jGui
        makeCorner(jf,10); makeStroke(jf,Color3.fromRGB(80,80,110),1.5,0)
        local jb=Instance.new("Frame"); jb.Size=UDim2.new(0,4,1,-10)
        jb.Position=UDim2.new(0,6,0,5); jb.BackgroundColor3=Color3.fromRGB(100,120,255)
        jb.BorderSizePixel=0; jb.Parent=jf; makeCorner(jb,4)
        local jn=Instance.new("TextLabel"); jn.Size=UDim2.new(1,-20,0,18)
        jn.Position=UDim2.new(0,16,0,5); jn.BackgroundTransparency=1; jn.Text="Bax"
        jn.TextColor3=Color3.fromRGB(160,170,220); jn.Font=Enum.Font.FredokaOne
        jn.TextSize=12; jn.TextXAlignment=Enum.TextXAlignment.Left; jn.Parent=jf
        local jm=Instance.new("TextLabel"); jm.Size=UDim2.new(1,-20,0,36)
        jm.Position=UDim2.new(0,16,0,24); jm.BackgroundTransparency=1; jm.Text=msg
        jm.TextColor3=Color3.fromRGB(210,215,240); jm.Font=Enum.Font.FredokaOne
        jm.TextSize=11; jm.TextXAlignment=Enum.TextXAlignment.Left
        jm.TextYAlignment=Enum.TextYAlignment.Top; jm.TextWrapped=true; jm.Parent=jf
        local ts=game:GetService("TweenService")
        ts:Create(jf,TweenInfo.new(0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
            {Position=UDim2.new(0.5,-150,1,-85)}):Play()
        task.delay(4,function()
            if jGui and jGui.Parent then
                ts:Create(jf,TweenInfo.new(0.4),{Position=UDim2.new(0.5,-150,1,10)}):Play()
                task.delay(0.4,function() pcall(function() jGui:Destroy() end) end)
            end
        end)
    end)
end

-- ============================================================
--  AD BLOCKER
-- ============================================================
local adBlockEnabled=false; local adBlockConns={}

local function stopAdBlock()
    for _,c in ipairs(adBlockConns) do pcall(function() c:Disconnect() end) end
    adBlockConns={}
end

local function startAdBlock()
    stopAdBlock()
    local function sweep()
        local n=0
        pcall(function()
            local pg=player:FindFirstChildOfClass("PlayerGui"); if not pg then return end
            for _,d in ipairs(pg:GetDescendants()) do
                if d.Name=="TemporaryPopUp" and d:IsA("Frame") then d:Destroy(); n=n+1 end
            end
        end)
        return n
    end
    local n=sweep()
    if n>0 then showBaxMsg("("..n..") Advertisement Found!") end
    pcall(function()
        local pg=player:FindFirstChildOfClass("PlayerGui"); if not pg then return end
        local c=pg.DescendantAdded:Connect(function(d)
            if not adBlockEnabled then return end
            if d.Name=="TemporaryPopUp" and d:IsA("Frame") then
                task.defer(function()
                    pcall(function() d:Destroy() end)
                    showBaxMsg("(1) Advertisement Found!")
                end)
            end
        end)
        table.insert(adBlockConns,c)
    end)
end

-- ============================================================
--  FRESHENER
-- ============================================================
local freshenerEnabled=false; local freshenerConns={}

local function stopFreshener()
    for _,c in ipairs(freshenerConns) do pcall(function() c:Disconnect() end) end
    freshenerConns={}
end

local function startFreshener()
    stopFreshener()
    pcall(function()
        local pg=player:FindFirstChildOfClass("PlayerGui"); if not pg then return end
        for _,c in ipairs(pg:GetChildren()) do
            if c.Name=="IchorScreen" then c:Destroy() end
        end
        local conn=pg.ChildAdded:Connect(function(child)
            if not freshenerEnabled then return end
            if child.Name=="IchorScreen" then
                task.defer(function() pcall(function() child:Destroy() end) end)
            end
        end)
        table.insert(freshenerConns,conn)
    end)
end

