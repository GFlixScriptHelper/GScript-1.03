--  BUILD UI
-- ============================================================
if scrollFrame then
    makeHeader("  BAX FEATURES",1)

    local info=Instance.new("Frame")
    info.Size=UDim2.new(1,-4,0,46); info.BackgroundColor3=Color3.fromRGB(14,14,22)
    info.BorderSizePixel=0; info.LayoutOrder=2; info.Parent=scrollFrame
    makeCorner(info,8); makeStroke(info,Color3.fromRGB(45,45,70),1,0)
    local infoLbl=Instance.new("TextLabel")
    infoLbl.Size=UDim2.new(1,-12,1,0); infoLbl.Position=UDim2.new(0,8,0,0)
    infoLbl.BackgroundTransparency=1
    infoLbl.Text="Ad Blocker removes TemporaryPopUp ads.\nFreshener removes the IchorScreen effect."
    infoLbl.TextColor3=Color3.fromRGB(120,125,150); infoLbl.Font=Enum.Font.FredokaOne
    infoLbl.TextSize=10; infoLbl.TextWrapped=true
    infoLbl.TextXAlignment=Enum.TextXAlignment.Left
    infoLbl.TextYAlignment=Enum.TextYAlignment.Center; infoLbl.Parent=info

    makeHeader("  AD BLOCKER",3)
    makeToggleRow("Ad Blocker by Bax",Color3.fromRGB(80,80,90),4,function(on)
        adBlockEnabled=on
        if on then
            startAdBlock()
            showBaxMsg("Alright the Ad Blocker is on, so the\nAdvertisements would stop popping up on your screen.")
        else
            stopAdBlock()
            showBaxMsg("Well thanks for using this Feature,\nif you needed? Just turned it on again.")
        end
    end)

    makeHeader("  FRESHENER",5)
    makeToggleRow("Freshener",Color3.fromRGB(60,160,100),6,function(on)
        freshenerEnabled=on
        if on then startFreshener() else stopFreshener() end
    end)

    makeHeader("  LIGHT VISION",7)
    local brightLoop=nil; local brightDetectNotified=false
    local origBrightness,origClockTime,origFogEnd,origGlobalShadows,origOutdoorAmbient
    makeToggleRow("Light Vision",Color3.fromRGB(255,200,60),8,function(on)
        if on then
            origBrightness=Lighting.Brightness; origClockTime=Lighting.ClockTime
            origFogEnd=Lighting.FogEnd; origGlobalShadows=Lighting.GlobalShadows
            origOutdoorAmbient=Lighting.OutdoorAmbient
            Lighting.Brightness=2; Lighting.ClockTime=14
            Lighting.FogEnd=100000; Lighting.GlobalShadows=false
            Lighting.OutdoorAmbient=Color3.fromRGB(128,128,128)
            showBaxMsg("The Feature is on so dont worry about the Blackouts. Except the others though...")
            brightDetectNotified=false
            brightLoop=RunService.RenderStepped:Connect(function()
                if Lighting.FogEnd<100000 or Lighting.GlobalShadows==true or Lighting.Brightness<1.5 then
                    if not brightDetectNotified then
                        brightDetectNotified=true; showBaxMsg("No Darkness for you.")
                        task.delay(5,function() brightDetectNotified=false end)
                    end
                end
                Lighting.Brightness=2; Lighting.ClockTime=14
                Lighting.FogEnd=100000; Lighting.GlobalShadows=false
                Lighting.OutdoorAmbient=Color3.fromRGB(128,128,128)
            end)
        else
            if brightLoop then brightLoop:Disconnect(); brightLoop=nil end
            brightDetectNotified=false
            Lighting.Brightness=origBrightness or 1; Lighting.ClockTime=origClockTime or 14
            Lighting.FogEnd=origFogEnd or 10000
            Lighting.GlobalShadows=origGlobalShadows~=nil and origGlobalShadows or true
            Lighting.OutdoorAmbient=origOutdoorAmbient or Color3.fromRGB(70,70,70)
            showBaxMsg("Well good luck there.")
        end
    end)

    makeHeader("  POLLEN REMOVAL",9)
    local pollenEnabled=false; local pollenConns={}
    local POLLEN_NAMES={
        "pollenStorm_ceilingHaze","pollenStorm_floorHaze","pollenStorm_intro",
        "pollenStorm_particles","pollenStorm_screen","SpringFever",
    }
    local function sweepPollen()
        local found=false
        for _,name in ipairs(POLLEN_NAMES) do
            local obj=workspace:FindFirstChild(name)
            if obj then obj:Destroy(); found=true end
        end
        return found
    end
    local function startPollenRemoval()
        local found=sweepPollen()
        if found then showBaxMsg("Alright the Freshener got sucked all the Spring Fever") end
        local c=workspace.ChildAdded:Connect(function(child)
            if not pollenEnabled then return end
            for _,name in ipairs(POLLEN_NAMES) do
                if child.Name==name then
                    task.defer(function() pcall(function() child:Destroy() end) end)
                    showBaxMsg("Alright the Freshener got sucked all the Spring Fever")
                    break
                end
            end
        end)
        table.insert(pollenConns,c)
    end
    local function stopPollenRemoval()
        for _,c in ipairs(pollenConns) do pcall(function() c:Disconnect() end) end
        pollenConns={}
    end
    makeToggleRow("Pollen Removal",Color3.fromRGB(100,200,80),10,function(on)
        pollenEnabled=on
        if on then
            startPollenRemoval()
            showBaxMsg("Alright, i'll hack their System to open their Vents automatically so you couldnt see the particles and smoke from the floor. except the side effects on you.")
        else
            stopPollenRemoval(); showBaxMsg("Just dont get high alright?")
        end
    end)
end

